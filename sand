import subprocess
import json

def run_local_semgrep_scan(target_repo_dir):
    """
    Runs Semgrep programmatically using our custom yaml rule profiles.
    """
    print("[*] Launching Semgrep engine scan pipeline...")
    
    cmd = [
        "semgrep", "scan",
        "--config", "security_rules.yaml",
        "--json",
        target_repo_dir
    ]
    
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=False)
        # Parse the JSON results produced by Semgrep's execution
        scan_data = json.loads(result.stdout)
        return scan_data.get("results", [])
    except Exception as e:
        print(f"[-] Semgrep execution engine error: {e}")
        return []

