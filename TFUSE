class AsynchronousNetworkBridge:
    """Listens on raw localhost port to securely accept connections from remote cloud miners."""
    def __init__(self, port=9999, processor_callback=None):
        self.port = port
        self.callback = processor_callback

    async def handle_client(self, reader, writer):
        print("🛰️ [Network Bridge] Direct encrypted TCP link verified from remote cloud.")
        try:
            data = await reader.read(4096)
            message = data.decode()
            if self.callback and message:
                await self.callback(message)
        except Exception as e:
            print(f"⚠️ [Network Exception] Error parsing network socket packet: {e}")
        finally:
            writer.close()
            await writer.wait_closed()

    async def start_listening(self):
        server = await asyncio.start_server(self.handle_client, '127.0.0.1', self.port)
        print(f"📡 [Sovereign Server] Secure socket routing engine listening on port {self.port}...")
        return server


