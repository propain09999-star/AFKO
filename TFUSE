# --- SECURE CRYPTOGRAPHIC BOUNDARY LAYER ---
SECRET_KEY = b"SOVEREIGN_ARCHITECT_FINAL_KEY_2026"

def generate_signed_packet(layer, vector, target, payload):
    payload_bytes = json.dumps(payload, sort_keys=True).encode()
    signature = hmac.new(SECRET_KEY, payload_bytes, hashlib.sha256).hexdigest()
    return json.dumps({
        "timestamp_epoch": int(time.time() * 1000),
        "source_layer": layer.upper(),
        "vector": vector.upper(),
        "target": target.upper(),
        "payload": payload,
        "signature": signature
    })

def verify_signed_packet(packet_json):
    try:
        data = json.loads(packet_json)
        received_sig = data.get("signature")
        if not received_sig:
            return False, "Unsigned data string rejected."
        payload_bytes = json.dumps(data["payload"], sort_keys=True).encode()
        expected_sig = hmac.new(SECRET_KEY, payload_bytes, hashlib.sha256).hexdigest()
        if hmac.compare_digest(received_sig, expected_sig):
            return True, data
        return False, "Cryptographic verification mismatch."
    except Exception as e:
        return False, f"Codec validation error: {str(e)}"


