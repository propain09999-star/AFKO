        self.q_table = np.zeros((4, 3)) 
        self.lr = 0.1

    def map_base_to_state(self, dna_base):
        """Maps native biological information into quantum states."""
        mapping = {'A': 0, 'T': 1, 'C': 2, 'G': 3}
        return mapping.get(dna_base, 0)

    def select_optimization_strategy(self, state):
        return np.argmax(self.q_table[state])

    def learn_from_reward(self, state, action, reward):
        self.q_table[state, action] += self.lr * (reward - self.q_table[state, action])

