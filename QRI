    target_url = f"https://anu.edu.au{total_bits}"
    
    try:
        response = requests.get(target_url, timeout=5)
        if response.status_code == 200:
            quantum_data = response.json()
            # Extract raw high-entropy string to use as our mutation seed
            entropy_string = quantum_data["data"][0]
            return {"status": "locked", "entropy_seed": entropy_string}
    except Exception as network_error:
        # Fallback to local cryptographic entropy matrix if web connection is lagging
        return {"status": "local_fallback", "entropy_seed": "system_cache_clear_override_0x9F"}
