version: '3.8'

services:
  # The Target Application Stack (Frontend proxy + Core Microservice)
  reverse-proxy:
    image: nginx:1.25-alpine
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
    ports:
      - "8080:80"
    depends_on:
      - app-service

  app-service:
    build:
      context: .
      dockerfile: Dockerfile
    environment:
      - APP_ENV=test

  # The Automated Fuzzer Container
  polyglot-fuzzer:
    image: alpine:latest
    depends_on:
      - reverse-proxy
    volumes:
      - ./tests/payloads:/payloads:ro
      - ./tests/fuzz_runner.sh:/fuzz_runner.sh:ro
    entrypoint: ["/bin/sh", "/fuzz_runner.sh"]
