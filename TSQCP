class SubQuantumFieldEngine:
    """Simulates a continuous execution field, tracking wave mutations 
    and sub-quantum phase shifts before they materialize as errors.
    """
    def __init__(self, field_dimensions: int = 8):
        self.dims = field_dimensions
        # Initialize a stable baseline wave function (Psi) representing a perfect system state
        self.baseline_wave = np.ones(self.dims, dtype=complex) / np.sqrt(self.dims)
        
    def capture_live_environmental_field(self, cpu: float, memory: float, latency: float) -> np.ndarray:
        """Converts raw, continuous physical metrics into a sub-quantum complex wave state."""
        # Normalize incoming metrics into angular phase shifts
        phase_cpu = (cpu / 100.0) * np.pi
        phase_mem = (memory / 100.0) * np.pi
        phase_lat = min(latency / 1000.0, 1.0) * np.pi
        
        # Construct a live complex vector reflecting the current environmental field
        live_wave = np.zeros(self.dims, dtype=complex)
        for i in range(self.dims):
            # Introduce continuous wave superposition using exponential phase factors
            phase_factor = (i * phase_cpu) + (i**2 * phase_mem) - (i**3 * phase_lat)
            live_wave[i] = np.exp(1j * phase_factor)
            
        # Normalize the field wave function
        norm = np.linalg.norm(live_wave)
        return live_wave / norm if norm > 0 else self.baseline_wave

    def calculate_field_divergence(self, live_wave: np.ndarray) -> Tuple[float, float]:
        """Computes sub-quantum metrics: Quantum Entropy and Energy Divergence (Delta E)."""
        # Quantum overlap (inner product squared) gives the survival probability of the healthy timeline
        overlap = np.abs(np.vdot(self.baseline_wave, live_wave))**2
        
        # Calculate Von Neumann style field entropy to measure structural chaos
        probabilities = np.abs(live_wave)**2
        # Avoid log(0) with a microscopic epsilon offset
        entropy = -np.sum(probabilities * np.log2(probabilities + 1e-15))
        
        # Energy divergence represents how violently the system state is warping away from baseline
        energy_divergence = np.abs(1.0 - overlap) * entropy
        return entropy, energy_divergence


