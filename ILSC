import json
from web3 import Web3

class SmartContractInterface:
    def __init__(self):
        # Public Sepolia Testnet RPC
        self.rpc_url = "https://ankr.com"
        self.w3 = Web3(Web3.HTTPProvider(self.rpc_url))
        
        # Standard Minimal ERC-20 Smart Contract ABI (Allows reading names, symbols, and balances)
        self.erc20_abi = json.loads('[{"constant":true,"inputs":[],"name":"name","outputs":[{"name":"","type":"string"}],"payable":false,"stateMutability":"view","type":"function"},{"constant":true,"inputs":[],"name":"symbol","outputs":[{"name":"","type":"string"}],"payable":false,"stateMutability":"view","type":"function"},{"constant":true,"inputs":[{"name":"_owner","type":"address"}],"name":"balanceOf","outputs":[{"name":"balance","type":"uint256"}],"payable":false,"stateMutability":"view","type":"function"},{"constant":true,"inputs":[],"name":"decimals","outputs":[{"name":"","type":"uint8"}],"payable":false,"stateMutability":"view","type":"function"}]')
        
        # Example: Mock LINK Token Contract Address on Sepolia Testnet
        self.token_contract_address = self.w3.to_checksum_address("0x779877A7B0D9E8603169DdbD7836e478b4624789")

    def query_token_state(self, target_wallet: str):
        """Queries a live deployed smart contract for state metrics."""
        if not self.w3.is_connected():
            print("[-] Unable to connect to blockchain node network.")
            return None

        # Bind to the live deployed smart contract
        contract = self.w3.eth.contract(address=self.token_contract_address, abi=self.erc20_abi)
        
        try:
            # Execute standard read-only 'View' functions on the contract
            name = contract.functions.name().call()
            symbol = contract.functions.symbol().call()
            decimals = contract.functions.decimals().call()
            
            # Fetch specific wallet balance from inside the contract state
            checksum_wallet = self.w3.to_checksum_address(target_wallet)
            raw_balance = contract.functions.balanceOf(checksum_wallet).call()
            
            # Formulate the human-readable token math adjustments
            actual_balance = raw_balance / (10 ** decimals)
            
            print(f"[+] Smart Contract Identified: {name} ({symbol})")
            print(f"[+] Managed Wallet Balance: {actual_balance} {symbol}")
            return actual_balance
            
        except Exception as e:
            print(f"[-] Smart Contract Interaction Fault: {str(e)}")
            return 0.0

if __name__ == "__main__":
    scanner = SmartContractInterface()
    # Querying a placeholder vital wallet address for validation
    scanner.query_token_state("0x0000000000000000000000000000000000000000")
