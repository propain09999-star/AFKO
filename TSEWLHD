                "CRITICAL_DISCONNECT": {"bg": "#ef4444", "txt": "#fef2f2", "label": "🚨 SECURITY THREAT / NETWORK DROP"}
            }
            
            # Check elapsed time since last packet to auto-trip alert flag
            time_since_last_pulse = time.time() - global_secured_engine.last_network_pulse_time
            if time_since_last_pulse > 5.0:
                global_secured_engine.network_health_status = "CRITICAL_DISCONNECT"
                
            cfg = status_map.get(global_secured_engine.network_health_status, status_map["NOMINAL_OPTIMAL"])
            history_json = json.dumps(global_secured_engine.hourly_history_log)
            
            html_interface = f"""
