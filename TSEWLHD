            """
            self.wfile.write(html_interface.encode('utf-8'))
        else:
            self.send_error(404)

    def do_POST(self):
        """Receives incoming data and forces strict verification token authentication."""
        if self.path == "/submit_secure_data":
            # Extract incoming transmission signature token from headers
            provided_signature = self.headers.get("X-Secure-Token-Signature", "")
            content_length = int(self.headers['Content-Length'])
            raw_post_body = self.rfile.read(content_length)
            
            # 🔐 SECURITY CHECK: Calculate expected HMAC-SHA256 signature
            computed_hmac = hmac.new(PRE_SHARED_SECRET_KEY, raw_post_body, hashlib.sha256).hexdigest()
            
            # Use constant-time comparison to prevent side-channel timing attacks
            if not hmac.compare_digest(computed_hmac, provided_signature):
                print("🚨 [SECURITY VIOLATION]: Rejected unauthorized data injection attempt!")
                self.send_response(401) # Unauthorized
                self.end_headers()
                self.wfile.write(json.dumps({"status": "ERROR", "reason": "INVALID_SIGNATURE_TOKEN"}).encode('utf-8'))
                return

            # If token verification matches, proceed safely with data pipeline
            global_secured_engine.update_network_pulse()
            packet = json.loads(raw_post_body.decode('utf-8'))
            node_id = packet.get("id", "UNKNOWN")
            text_data = packet.get("text", "")
            
            # Compress and clean up trace memory instantly
            dna_block = global_secured_engine.compress_text_to_dna(text_data)
            current_hour = time.strftime("%Y-%m-%d %H:00")
            
            with global_secured_engine.lock:
                global_secured_engine.total_bytes_processed_this_hour += len(raw_post_body)
                global_secured_engine.hourly_history_log[current_hour] = global_secured_engine.hourly_history_log.get(current_hour, 0) + len(raw_post_body)
            
            # Save payload block straight to disk folder
            out_file_path = os.path.join(global_secured_engine.paths["COMPRESSED"], f"{node_id}.dna")
            with open(out_file_path, "w") as out_f:
                out_f.write(dna_block)
                
            self.send_response(200)
            self.send_header("Content-type", "application/json")
            self.end_headers()
            self.wfile.write(json.dumps({"status": "AUTHENTICATED_AND_COMPRESSED", "saved_node": node_id}).encode('utf-8'))

# ──────────────────────────────────────────────────────────
# 🚀 CLIENT SIMULATOR SCRIPT HOOK
# ──────────────────────────────────────────────────────────
class SecuredClientTransmitter:
    def __init__(self, host="127.0.0.1", port=8080):
        self.host = host
        self.port = port

    def transmit_authenticated_packet(self, node_id: str, text: str) -> bool:
        """Packages text data, computes a valid crypto token, and streams to server."""
        import http.client
        payload_data = json.dumps({"id": node_id, "text": text}).encode('utf-8')
        
        # Generate valid authorization signature token
        client_signature = hmac.new(PRE_SHARED_SECRET_KEY, payload_data, hashlib.sha256).hexdigest()
        
        try:
            conn = http.client.HTTPConnection(self.host, self.port, timeout=1.0)
            headers = {
                "Content-type": "application/json",
                "Content-Length": str(len(payload_data)),
                "X-Secure-Token-Signature": client_signature
            }
            conn.request("POST", "/submit_secure_data", body=payload_data, headers=headers)
            response = conn.getresponse()
            status = response.status == 200
            conn.close()
            return status
        except Exception:
            return False

