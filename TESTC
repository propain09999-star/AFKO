    def __init__(self, local_repo_root="./my_sovereign_repos"):
        self.repo_root = local_repo_root
        if not os.path.exists(self.repo_root):
            os.makedirs(self.repo_root)

    async def ingest_local_repo(self, repo_name, local_path):
        """Scans code files inside your repositories to map dependencies and look for optimizations."""
        print(f"📂 [Repo Analyzer] Indexing repository files inside: {repo_name}")
        found_signals = []
        try:
            if os.path.exists(local_path):
                for root, dirs, files in os.walk(local_path):
                    for file in files:
                        if file.endswith(('.py', '.rs', '.go', '.cpp', '.js')):
                            file_path = os.path.join(root, file)
                            with open(file_path, 'r', errors='ignore') as f:
                                content = f.read()
                                # Reasoning lookups: identify unhandled exceptions or hardcoded paths
                                if "TODO" in content or "FIXME" in content:
                                    found_signals.append({"file": file, "issue": "Unfinished logic marker detected"})
            return generate_signed_packet("QUARK", "REPO_ANALYSIS_COMPLETE", repo_name, {"anomalies": found_signals})
        except Exception as e:
            print(f"⚠️ [Repo Error] Failed reading repository structure: {e}")
            return None


