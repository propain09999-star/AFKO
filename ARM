import os
import sys
import time
import subprocess
import polars as pl
import duckdb

class MotoGSystemController:
    def __init__(self, target_db_path="storage_core.duckdb"):
        self.max_model_ram_gb = 4.5
        self.target_db_path = target_db_path
        
        # Initialize DuckDB on persistent storage with wear-optimized configurations
        self.db_conn = duckdb.connect(database=self.target_db_path)
        self._optimize_db_settings()

    def _optimize_db_settings(self):
        """Applies explicit performance parameters to minimize flash disk wear."""
        self.db_conn.execute(f"""
            PRAGMA memory_limit='7.5GB';
            PRAGMA checkpoint_threshold='1GB';
            PRAGMA wal_autocheckpoint=10000;
            CREATE TABLE IF NOT EXISTS archive_ledger (
                tx_id VARCHAR PRIMARY KEY,
                amount DOUBLE,
                timestamp TIMESTAMP
            );
        """)

    def get_process_ram_usage(self, process_name="llama-cli"):
        """Gathers precise RSS memory footprints via native subsystem checks."""
        try:
            pid_bytes = subprocess.check_output(["pgrep", "-f", process_name])
            pids = pid_bytes.decode('utf-8').strip().split('\n')
            total_rss_kb = 0
            for pid in pids:
                if pid:
                    with open(f"/proc/{pid}/status", "r") as f:
                        for line in f:
                            if "VmRSS:" in line:
                                total_rss_kb += int(line.split()[1])
            return total_rss_kb / (1024 * 1024) # Return GB
        except Exception:
            return 0.0 # Process not running

    def enforce_cqb_memory_guardrail(self):
        """Acts as a host-level sentinel to manage model memory consumption."""
        current_ram = self.get_process_ram_usage()
        print(f"[Monitor] Current Model RAM Footprint: {current_ram:.2f} GB / {self.max_model_ram_gb} GB")
        
        if current_ram > self.max_model_ram_gb:
            print("[CQB EXECUTOR] Memory boundary breached! Forcing context fold reset...")
            # Silently notify llama.cpp to clear context registers by restarting process safely
            os.system("pkill -HUP llama-cli")
            return True
        return False

    def flash_optimized_archive(self, memory_dataframe: pl.DataFrame):
        """Flushes in-memory data tables using sequential Parquet chunk allocation."""
        if memory_dataframe.height == 0:
            return
            
        print(f"[Archiver] Processing {memory_dataframe.height} rows into wear-leveled blocks...")
        pandas_df = memory_dataframe.to_pandas()
        
        # Execute unified transactional insert block
        self.db_conn.execute("BEGIN TRANSACTION;")
        self.db_conn.execute("INSERT OR IGNORE INTO archive_ledger SELECT * FROM pandas_df;")
        self.db_conn.execute("COMMIT;")
        
        # Explicitly run checkpointing to write straight to disk sequentially, avoiding fragmentation
        self.db_conn.execute("FORCE CHECKPOINT;")
        print("[Archiver] Flash storage update successfully finalized.")

