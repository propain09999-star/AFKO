import hashlib
import json
import time
import math
import numpy as np

class MetabolicAGIEngine:
    def __init__(self, dimensions=128):
        self.dimensions = dimensions
        self.bin_to_dna = {'00': 'A', '01': 'C', '10': 'G', '11': 'T'}
        self.dna_to_bin = {v: k for k, v in self.bin_to_dna.items()}
        
        # Vault Storage & Local Space
        self.local_vault = {}
        self.vector_space = {}
        
        # --- SYNAPTIC CONSOLIDATION TRACKING ---
        # Tracks importance scores (Fisher Information approximation) to protect core weights
        self.synaptic_consolidation_matrix = {}
        
        # --- CHEMICAL REFRACTORY PERIOD REGISTRY ---
        # Tracks how many cycles a specific sector must sleep after firing
        self.refractory_registry = {}

    # 1. LATENCY ENGINE: CHEMICAL REFRACTORY PERIOD GATE
    def enforce_refractory_gate(self, cid: str, current_time: float, lockout_duration=0.5) -> bool:
        """Locks out hyper-active nodes from computational paths to minimize mid-inference latency."""
        if cid in self.refractory_registry:
            last_fired = self.refractory_registry[cid]
            if current_time - last_fired < lockout_duration:
                # Node is in a chemical resting phase; skip calculation
                return True
        return False

    # 2. INFERENCE OPTIMIZER: GABA / GLUTAMATE INHIBITORY MASKING
    def generate_gaba_inhibitory_mask(self, query_vector: list, excitation_threshold=0.6) -> set:
        """Generates a topological blocker mask to instantly blind 80% of irrelevant data tracks."""
        blocked_cids = set()
        q_vec = np.array(query_vector)
        
        for cid, vault_vector in self.vector_space.items():
            v_vec = np.array(vault_vector)
            # Fast bitwise similarity check
            mismatches = np.count_nonzero(q_vec != v_vec)
            alignment = 1 - (mismatches / self.dimensions)
            
            # GABA Inhibition: If the node does not meet excitation requirements, mask it completely
            if alignment < excitation_threshold:
                blocked_cids.add(cid)
                
        return blocked_cids

    # 3. METABOLIC COMPUTE BUDGET & SYNAPTIC FINE-TUNING
    def ingest_node_with_metabolic_loss(self, text: str, title: str, memory_importance: float):
        """Ingests code/text while mapping metabolic constraints and stabilizing core synapses."""
        payload = json.dumps({"m": {"t": title}, "t": text})
        payload_bytes = payload.encode('utf-8')
        cid = hashlib.sha256(payload_bytes).hexdigest()[:16]
        
        # Loss Optimization Limit (Simulated ATP budget constraint)
        available_atp = max(10, int(100 * (1.0 - memory_importance)))
        truncated_text = text[:available_atp]
        
        # Re-encode payload matching budget limits
        optimized_payload = json.dumps({"m": {"t": title}, "t": truncated_text})
        optimized_bytes = optimized_payload.encode('utf-8')
        
        # Quaternary DNA translation
        binary_str = ''.join(f'{b:08b}' for b in optimized_bytes)
        protected_binary = binary_str + binary_str # Parity
        dna_matrix = ''.join(self.bin_to_dna[protected_binary[i:i+2]] for i in range(0, len(protected_binary), 2))
        
        # Coordinate allocation
        hash_seed = int(hashlib.md5(truncated_text.encode('utf-8')).hexdigest(), 16) % (2**32)
        np.random.seed(hash_seed)
        b_vector = (np.random.randn(self.dimensions) > 0).astype(int).tolist()
        
        # 5. SYNAPTIC CONSOLIDATION ENGINE
        if cid in self.synaptic_consolidation_matrix and self.synaptic_consolidation_matrix[cid] > 0.8:
            print(f"🔒 CRITICAL MEMORY PROTECTION: [CID: {cid}] is structurally consolidated. Overwrite blocked.")
            return

        # Commit to Mobile Vault
        self.local_vault[cid] = dna_matrix
        self.vector_space[cid] = b_vector
        self.synaptic_consolidation_matrix[cid] = memory_importance
        print(f"📥 Node saved with Metabolic Budget. Structural Synaptic Rigidity set to: {memory_importance}")

    # 4. NETWORK DISTRIBUTOR: TRITROPHIC QUERY DIFFUSION LOOP
    def execute_tritrophic_diffusion(self, user_query: str) -> list:
        """Emits semantic vectors like airborne distress vapors across a P2P local swarm cluster."""
        current_time = time.time()
        query_vector = (np.random.randn(self.dimensions) > 0).astype(int).tolist()
        
        # Apply GABA Blocker Routine to shield downstream layers from processing noise
        inhibited_nodes = self.generate_gaba_inhibitory_mask(query_vector, excitation_threshold=0.45)
        print(f"🚫 GABA Neuromodulation active: Blocked {len(inhibited_nodes)} of {len(self.vector_space)} database sectors.")
        
        discovered_payloads = []
        q_vec = np.array(query_vector)
        
        for cid, vault_vector in self.vector_space.items():
            if cid in inhibited_nodes:
                continue # Skip processing entirely - zero compute used
                
            if self.enforce_refractory_gate(cid, current_time):
                print(f"⏱️ REFRACTORY BLOCK: Sector {cid} is resetting its chemical channels. Bypassing node calculation.")
                continue
                
            v_vec = np.array(vault_vector)
            mismatches = np.count_nonzero(q_vec != v_vec)
            score = int((1 - (mismatches / self.dimensions)) * 100)
            
            # Log active activation time to trigger Refractory Period lockouts
            self.refractory_registry[cid] = current_time
            discovered_payloads.append((cid, score))
            
        return sorted(discovered_payloads, key=lambda x: x[1], reverse=True)

