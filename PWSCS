import json
import time
import http.client
import urllib.parse

class ProductionNetworkScraperClient:
    def __init__(self, host="127.0.0.1", port=8080):
        self.host = host
        self.port = port
        self.target_url = "/submit_data"
        self.total_bytes_transmitted = 0

    def stream_packet_over_network(self, node_id: str, raw_text_content: str) -> dict:
        """Establishes a real TCP/IP socket connection to transmit JSON payloads."""
        start_time = time.perf_counter_ns()
        
        # 📦 STEP 1: Package the raw text into a standard structured framework JSON
        payload_dict = {
            "id": node_id,
            "timestamp": time.time(),
            "source": "ChromeObscuraInvisibleBrowser",
            "text": raw_text_content
        }
        json_payload_string = json.dumps(payload_dict)
        payload_bytes = json_payload_string.encode('utf-8')
        
        # Track the absolute network weight of this data packet
        packet_size = len(payload_bytes)
        
        try:
            # 📡 STEP 2: Open a native HTTP socket connection directly to the phone server
            connection = http.client.HTTPConnection(self.host, self.port, timeout=2.0)
            
            headers = {
                "Content-type": "application/json",
                "Content-Length": str(packet_size),
                "User-Agent": "ChromeObscuraClient/1.0"
            }
            
            # 🚀 STEP 3: Transmit the raw data blocks over the wire
            connection.request("POST", self.target_url, body=json_payload_string, headers=headers)
            
            # Read back the server's acknowledgment payload
            response = connection.getresponse()
            response_data = response.read().decode('utf-8')
            connection.close()
            
            end_time = time.perf_counter_ns()
            latency_us = (end_time - start_time) / 1000
            
            self.total_bytes_transmitted += packet_size
            
            return {
                "status": "TRANSMITTED",
                "server_code": response.status,
                "latency_microseconds": latency_us,
                "bytes_sent": packet_size,
                "server_reply": json.loads(response_data) if response.status == 200 else response_data
            }
            
        except Exception as e:
            return {
                "status": "CONNECTION_FAILED",
                "error_message": str(e)
            }

