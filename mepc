import os
import json
import subprocess
import httpx
import docker
import git

class ProductionSecurityAgent:
    def __init__(self, repo_url, language, discord_url=None, tg_token=None, tg_chat_id=None):
        self.repo_url = repo_url
        self.language = language
        self.repo_name = repo_url.split("/")[-1].replace(".git", "")
        self.local_path = f"./tmp/{self.repo_name}"
        
        # Alerts Setup
        self.discord_url = discord_url or os.getenv("DISCORD_WEBHOOK_URL")
        self.tg_token = tg_token or os.getenv("TELEGRAM_BOT_TOKEN")
        self.tg_chat_id = tg_chat_id or os.getenv("TELEGRAM_CHAT_ID")
        
        # Docker Base Image Mappings
        self.image_map = {
            "python": "python:3.11-slim",
            "go": "golang:1.22-alpine",
            "javascript": "node:20-slim"
        }

    def dispatch_alert(self, severity, message):
        """
        Dispatches structured notification payloads across all configured vectors.
        """
        payload_text = f"[{severity.upper()}] Security Pipeline Alert\nRepository: {self.repo_name}\nDetails: {message}"
        print(f"\n[ALERT] {payload_text}\n")
        
        # 1. Local Audit Log
        with open("pipeline_security_audit.log", "a", encoding="utf-8") as log_file:
            log_file.write(f"{payload_text}\n{'-'*40}\n")
            
        # 2. Discord Webhook
        if self.discord_url:
            try:
                httpx.post(self.discord_url, json={"content": f"```{payload_text}```"}, timeout=5.0)
            except Exception as e:
                print(f"[-] Discord alerting failed: {e}")
                
        # 3. Telegram Channels
        if self.tg_token and self.tg_chat_id:
            try:
                tg_url = f"https://telegram.org{self.tg_token}/sendMessage"
                httpx.post(tg_url, json={"chat_id": self.tg_chat_id, "text": payload_text}, timeout=5.0)
            except Exception as e:
                print(f"[-] Telegram alerting failed: {e}")

    def run_sandbox_command(self, container, command):
        """Helper to run a string command inside the network-isolated container."""
        result = container.exec_run(cmd=f"sh -c '{command}'")
        return result.exit_code, result.output.decode('utf-8', errors='ignore')

    def execute_pipeline(self):
        self.dispatch_alert("info", "Starting automation loop crawl execution sequence.")
        
        # Clone Repo safely via raw Git
        if os.path.exists(self.local_path):
            subprocess.run(["rm", "-rf", self.local_path])
        git.Repo.clone_from(self.repo_url, self.local_path)
        
        # Initialize Isolated Container
        client = docker.from_env()
        target_image = self.image_map.get(self.language, "ubuntu:latest")
        
        container = client.containers.run(
            image=target_image,
            command="tail -f /dev/null",
            volumes={os.path.abspath(self.local_path): {'bind': '/app', 'mode': 'rw'}},
            detach=True,
            network_disabled=True,
            mem_limit="512m"
        )
        
        try:
            # Step 1: Pre-patch validation (Verify standard build runs correctly)
            build_cmds = {"python": "python3 -m py_compile /app/*.py", "go": "cd /app && go build ./...", "javascript": "cd /app && npm install --dry-run"}
            exit_code, output = self.run_sandbox_command(container, build_cmds.get(self.language, "true"))
            
            if exit_code != 0:
                self.dispatch_alert("warning", f"Base repository package failed initial build check. Stopping analysis.\nLog: {output[:200]}")
                return

            # Step 2: Local Rule Scanning Engine
            semgrep_cmd = ["semgrep", "scan", "--config", "security_rules.yaml", "--json", self.local_path]
            scan_res = subprocess.run(semgrep_cmd, capture_output=True, text=True, check=False)
            
            try:
                findings = json.loads(scan_res.stdout).get("results", [])
            except Exception:
                findings = []

            for vuln in findings:
                file_path = vuln['path']
                self.dispatch_alert("critical", f"Semgrep matched architectural vulnerability template inside: {file_path}")
                
                # [AI Mock Remediation Step] 
                # Read structural code, apply zero-day upgrades / structural validation patches here.
                with open(file_path, "r") as f:
                    old_code = f.read()
                
                # Simulating an AI upgrader engine rewriting a flaw safely
                new_patched_code = old_code.replace("os.system(", "subprocess.run(shlex.split(")
                with open(file_path, "w") as f:
                    f.write(new_patched_code)
                
                # Step 3: Automated Sandbox Upgrader Testing Validation Loop
                # Run the project's native verification test suite inside the container to guarantee nothing broke
                test_cmds = {"python": "pytest /app/tests/ or python3 -m unittest discover /app", "go": "cd /app && go test ./...", "javascript": "cd /app && npm test"}
                test_exit_code, test_output = self.run_sandbox_command(container, test_cmds.get(self.language, "true"))
                
                if test_exit_code == 0:
                    self.dispatch_alert("success", f"Zero-Day upgrade validated successfully. Test suite passed on isolated patch verification.\nFile: {file_path}")
                else:
                    self.dispatch_alert("error", f"AI patch created regression failure. Integrated tests broken.\nFile: {file_path}\nLog: {test_output[:300]}")

        finally:
            # Structural breakdown clean up loop
            container.stop()
            container.remove()

if __name__ == "__main__":
    # Execution parameters example configuration passing
    pipeline = ProductionSecurityAgent(
        repo_url="https://codeberg.org",
        language="python",
        discord_url="https://discord.com",
        tg_token="123456:your-telegram-token",
        tg_chat_id="your-chat-id"
    )
    pipeline.execute_pipeline()
