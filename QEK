import os
import json
import shutil
import hashlib
import numpy as np

class LocalHardwareQuantumVault:
    def __init__(self, vault_path="secured_vault.enc"):
        self.vault_path = vault_path

    def sample_hardware_entropy(self) -> str:
        """
        Samples unique physical system data points from the local device hardware layout.
        This extracts dynamic entropy variations to secure key encryption steps.
        """
        # Capture precise, changing local storage byte distributions
        total, used, free = shutil.disk_usage("/")
        
        # Read the current load average metrics from the Linux operating system
        load_avg = os.getloadavg() if hasattr(os, "getloadavg") else (0.1, 0.5, 0.9)
        
        # Combine parameters into a singular, localized physical hardware string
        hardware_signature = f"{free}-{load_avg[0]}-{total}"
        return hardware_signature

    def generate_quantum_key_from_entropy(self, entropy_string: str) -> bytes:
        """
        Transforms raw system text metrics into a balanced 32-byte cryptographic key matrix
        using a mathematical Fourier Transform simulation layer.
        """
        ascii_values = [ord(char) for char in entropy_string]
        # Pad up to fixed vector bounds
        padded = ascii_values + [0] * (64 - len(ascii_values) % 64)
        
        # Execute Fast Fourier Transform to find the core resonant spike profile
        fft_array = np.abs(np.fft.fft(np.array(padded, dtype=float)))
        harmonic_hash_base = "".join([str(int(val)) for val in fft_array[:8]])
        
        # Output a clean 256-bit structural hash key signature
        return hashlib.sha256(harmonic_hash_base.encode('utf-8')).digest()

    def lock_private_key(self, raw_private_key: str):
        """Encrypts and secures your private blockchain key text into local storage layers."""
        entropy = self.sample_hardware_entropy()
        crypto_key = self.generate_quantum_key_from_entropy(entropy)
        
        # Perform a direct XOR state transform against the computed key matrix bits
        raw_bytes = raw_private_key.encode('utf-8')
        encrypted_bytes = bytes([b ^ crypto_key[i % len(crypto_key)] for i, b in enumerate(raw_bytes)])
        
        payload = {
            "identity": "StaticObserverHardwareVault",
            "encrypted_blob_hex": encrypted_bytes.hex()
        }
        
        with open(self.vault_path, "w") as f:
            json.dump(payload, f, indent=4)
        print(f"[+] Key safely locked within local hardware quantum vault.")

    def unlock_private_key(self) -> str:
        """Attempts to decrypt the private file utilizing real-time device hardware footprints."""
        if not os.path.exists(self.vault_path):
            print("[-] Vault Access Denied: Secure payload container file not found.")
            return ""
            
        with open(self.vault_path, "r") as f:
            payload = json.load(f)
            
        encrypted_bytes = bytes.fromhex(payload["encrypted_blob_hex"])
        
        # Re-sample hardware variables to calculate the current system state vector
        entropy = self.sample_hardware_entropy()
        crypto_key = self.generate_quantum_key_from_entropy(entropy)
        
        decrypted_bytes = bytes([b ^ crypto_key[i % len(crypto_key)] for i, b in enumerate(encrypted_bytes)])
        
        try:
            decrypted_string = decrypted_bytes.decode('utf-8')
            return decrypted_string
        except Exception:
            print("[-] Decryption Failure: Structural mismatch in local hardware signatures.")
            return ""

if __name__ == "__main__":
    vault = LocalHardwareQuantumVault()
    # Securely lock a test private wallet key string into the database
    vault.lock_private_key("0x0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef")
    
    # Immediately try to read it back while the system metrics are still aligned
    recovered_key = vault.unlock_private_key()
    print(f"[+] Decrypted Verification Key Output: {recovered_key[:10]}...")
