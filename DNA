syntax = "proto3";

package digital_brain;

// The universal cognitive state traveling across the polyglot graph network
message CognitiveState {
  string session_id = 1;
  string original_query = 2;
  
  // The structural routing instructions calculated by Ruby/Python
  RoutingMap routing_map = 3;
  
  // The raw sensory payloads captured by Node.js from Free Web APIs
  repeated ApiPayload raw_payloads = 4;
  
  // System health, threat indicators, and error tracking
  SystemHealth status = 5;
}

message RoutingMap {
  string dominant_intent = 1;
  repeated string target_api_nodes = 2;
  int32 execution_priority = 3; // 1 to 10 scale
}

message ApiPayload {
  string source_api_name = 1;
  string url_endpoint = 2;
  bytes raw_bytes = 3;         // Unfolded, unstructured raw binary data
  int64 captured_timestamp = 4;
}

message SystemHealth {
  bool circuit_tripped = 1;
  string error_message = 2;
  string failing_node = 3;
  int32 retry_count = 4;
}
