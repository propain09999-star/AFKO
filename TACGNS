@app.get("/power_status")
def get_charging_telemetry():
    """Exposes current device power status and system thermal parameters."""
    is_plugged = engine.check_charging_status()
    return {
        "device_state": "CHARGING_PROCESSING_UNLOCKED" if is_plugged else "BATTERY_ECO_HALT",
        "power_plugged_detected": is_plugged,
        "core_temperature_celsius": engine.system_temp,
        "pending_queue_directory": engine.paths["INBOUND_DROPZONE"]
    }

# ──────────────────────────────────────────────────────────
# 🚀 DEPLOYMENT DRIVER ROUTINE
# ──────────────────────────────────────────────────────────
def deploy_system():
    print("─── INITIALIZING CHARGING-GATED MULTI-PATHWAY STACK ───\n")
    
    # 1. Run the Charging Gated Watcher loop on a background thread
    watcher_thread = threading.Thread(target=engine.charging_gated_observer_loop)
    watcher_thread.daemon = True
    watcher_thread.start()
    
    # 2. Simulate dropping a web-scraped text document into the monitored folder
    test_file = os.path.join(engine.paths["INBOUND_DROPZONE"], "scraped_packet.txt")
    with open(test_file, "w", encoding="utf-8") as f:
        f.write("Periodic table configurations match unstable alkali data matrix structures cleanly.")
        
    # Allow the charging thread pulse to parse the document
    time.sleep(0.6)
    
    # 3. Spin up local FastAPI networking tools if available
    if FASTAPI_AVAILABLE:
        print("\n🌐 [FASTAPI ROUTER]: Launching local network diagnostic service...")
        print("      👉 Open http://127.0.0 to track charging modes.")
        uvicorn.run(app, host="127.0.0.1", port=8000, log_level="warning")
    else:
        print("\n🌐 [FASTAPI NOTE]: Core extensions offline. Simulation loops ran completely clean.")
        
    engine.is_running = False
    watcher_thread.join(timeout=0.1)
    print("\n🟢 PIPELINE DEPLOYED: Energy profiles balanced perfectly. System stays completely cool.")

if __name__ == "__main__":
    deploy_system()
