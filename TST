import hashlib
import hmac

# --- CRYPTOGRAPHIC INTELLIGENCE VALIDATION ---
def verify_incoming_packet(packet_json, secret_key=b"SOVEREIGN_ARCHITECT_SECRET"):
    """
    Validates payload integrity using HMAC-SHA256 signatures.
    Ensures remote cloud boxes have not been intercepted or altered.
    """
    try:
        data = json.loads(packet_json)
        received_signature = data.get("signature")
        if not received_signature:
            return False, "Missing cryptographic signature."
        
        # Recompute hash based on core telemetry payload
        payload_bytes = json.dumps(data["payload"], sort_keys=True).encode()
        expected_signature = hmac.new(secret_key, payload_bytes, hashlib.sha256).hexdigest()
        
        if hmac.compare_digest(received_signature, expected_signature):
            return True, data
        return False, "Signature mismatch. Data untrusted."
    except Exception as e:
        return False, f"Validation failure: {str(e)}"

def generate_signed_packet(source_layer, vector, target, payload, secret_key=b"SOVEREIGN_ARCHITECT_SECRET"):
    """Utility to sign payloads at the remote collection node before transport."""
    payload_bytes = json.dumps(payload, sort_keys=True).encode()
    signature = hmac.new(secret_key, payload_bytes, hashlib.sha256).hexdigest()
    return json.dumps({
        "timestamp_epoch": int(time.time() * 1000),
        "source_layer": source_layer.upper(),
        "vector": vector.upper(),
        "target": target.upper(),
        "payload": payload,
        "signature": signature
    })


