import os
import sys
import subprocess
import ast

class PolyglotCodeMutator:
    def __init__(self, repo_dir="."):
        self.repo_dir = repo_dir
        print("[+] Polyglot Code Mutation & Git Automation Engine Armed.")

    def run_git_command(self, args: list) -> str:
        """Executes a terminal Git instruction within the target directory."""
        try:
            res = subprocess.run(["git"] + args, cwd=self.repo_dir, capture_output=True, text=True, check=True)
            return res.stdout.strip()
        except subprocess.CalledProcessError as e:
            print(f"[-] Git Protocol Error: {e.stderr.strip()}")
            return ""

    def mutate_script_to_polyglot(self, target_python_file: str):
        """
        Injects a structural Polyglot wrapper into a raw Python file.
        This turns a normal script into a hybrid Bash/Python file on the fly.
        """
        if not os.path.exists(target_python_file) or not target_python_file.endswith(".py"):
            return

        with open(target_python_file, "r") as f:
            original_content = f.read()

        # If the script is already wrapped, pass it by to prevent nested loops
        if original_content.startswith("#!/bin/bash"):
            return

        print(f"[🧬] Mutating target script into Polyglot structure: {target_python_file}")

        # Construct the universal polyglot header block
        polyglot_header = """#!/bin/bash
# \"\"\" (Hides Bash commands inside a Python multi-line string block)
echo "[+] Initializing Polyglot Node Runtime Layer via Terminal Bash..."
python3 "$0" "$@"
exit $?
# \"\"\"
"""
        mutated_content = polyglot_header + original_content

        with open(target_python_file, "w") as f:
            f.write(mutated_content)
        
        # Adjust local file access permissions to allow terminal execution
        os.chmod(target_python_file, 0o755)
        print(f"[+] Mutation locked. {target_python_file} is now a standalone executable.")

    def sync_pull_and_upgrade(self):
        """Pulls updates from remote repositories and upgrades all scripts automatically."""
        print("[>] Querying remote GitHub registry for incoming code streams...")
        pull_results = self.run_git_command(["pull", "origin", "main"])
        print(f"[+] Git Pull Output: {pull_results}")

        # Scan the local system registry and upgrade any newly pulled python scripts
        for file in os.listdir(self.repo_dir):
            if file.endswith(".py") and file != "cosmic_mutator.py":
                self.mutate_script_to_polyglot(os.path.join(self.repo_dir, file))

    def autonomous_commit_and_push(self, modification_reason: str):
        """Stages local code changes, generates a git commit, and pushes to GitHub."""
        print(f"[>] Syncing optimized localized logic back to the main repository grid...")
        self.run_git_command(["add", "."])
        
        commit_msg = f"Autonomous System Mutation: {modification_reason}"
        commit_results = self.run_git_command(["commit", "-m", commit_msg])
        print(f"[+] Git Commit Matrix: {commit_results}")

        push_results = self.run_git_command(["push", "origin", "main"])
        print(f"[+] GitHub Sync Matrix: {push_results}")

if __name__ == "__main__":
    mutator = PolyglotCodeMutator()
    # Test checking for incoming remote changes and upgrading the codebase
    mutator.sync_pull_and_upgrade()
