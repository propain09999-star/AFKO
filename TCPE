def create_telemetry_packet(layer, vector, target, telemetry):
    return {
        "epoch_ms": int(time.time() * 1000),
        "layer": layer.upper(),       # "SUB_QUARK", "QUARK", "GRID_TELEMETRY"
        "vector": vector.upper(),     # "POWER_SURGE", "MIASMA_EXPLOIT", "COMPILER_DEADLOCK"
        "target": target.upper(),     # "PJM_VA", "ERCOT_TX", "CAISO_CA", "ARCH_LINUX"
        "telemetry": telemetry
    }

